{
  "name": "opn",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "build:schema": "node --experimental-strip-types scripts/build-schema.ts",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "husky install",
    "commit": "git-cz",
    "release": "standard-version --no-verify",
    "release:major": "pnpm run release -- --release-as major",
    "release:minor": "pnpm run release -- --release-as minor",
    "release:patch": "pnpm run release -- --release-as patch",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@astrojs/cloudflare": "12.6.12",
    "@astrojs/react": "4.4.2",
    "@astrojs/sitemap": "3.6.0",
    "@neondatabase/serverless": "1.0.2",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@upstash/redis": "^1.38.0",
    "astro": "5.16.1",
    "dotenv": "17.2.3",
    "drizzle-orm": "0.45.0",
    "framer-motion": "11.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "5.0.1",
    "zod": "4.0.10"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@commitlint/cli": "18.4.4",
    "@commitlint/config-conventional": "18.4.4",
    "autoprefixer": "10.4.17",
    "clipboardy": "4.0.0",
    "commitizen": "4.3.0",
    "cz-conventional-changelog": "3.3.0",
    "drizzle-kit": "0.31.4",
    "husky": "8.0.3",
    "lint-staged": "15.2.0",
    "postcss-html": "1.6.0",
    "postcss-nesting": "12.0.2",
    "standard-version": "9.5.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.9.5"
  }
}
